SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# Optional: LLM APIs (used in later phases for theme extraction / summarization)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Reddit API credentials (used in Phase 2 for Reddit ingestion)
# If not available, the scraper will use Reddit's public JSON endpoints as fallback
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=spotify-review-engine/0.1 by your-reddit-username
